# Backend container + backend Postgres container.
# Kafka is provided by the logic-core compose in ../transan.

POSTGRES_DB=transan_backend
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres

TZ=Europe/Moscow
DATABASE_URL=jdbc:postgresql://backend-postgres:5432/transan_backend
DATABASE_USERNAME=postgres
DATABASE_PASSWORD=postgres

JWT_SECRET=0d986f028138826feb30028c1f1af82ad3b0c7429802377b463cd1a3edeafeb6
JWT_EXPIRATION_MS=3600000
JWT_REFRESH_EXPIRATION_MS=604800000
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
FORECAST_TIMEOUT_SECONDS=180

KAFKA_BROKERS=kafka:9092
KAFKA_FORECAST_PRODUCER_TOPIC=transan.forecast.input
KAFKA_FORECAST_CONSUMER_TOPIC=transan.forecast.output
KAFKA_CONSUMER_GROUP=user-backend
